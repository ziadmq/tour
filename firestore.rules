rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'kafehazyad5@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validation Blueprints ---
    function isValidBooking(data) {
      return data.keys().hasAll(['tripId', 'tripTitle', 'customerName', 'customerPhone', 'status', 'createdAt', 'updatedAt'])
        && data.tripId is string && data.tripId.size() <= 64
        && data.tripTitle is string && data.tripTitle.size() <= 128
        && data.customerName is string && data.customerName.size() >= 2
        && data.customerPhone is string && data.customerPhone.size() >= 8
        && data.status in ['pending', 'confirmed', 'cancelled']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['title', 'destination', 'description', 'price', 'duration', 'startDate', 'groupSize', 'image', 'highlights', 'includes', 'excludes', 'itinerary', 'gallery', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.destination is string && data.destination.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.price is string && data.price.size() <= 100
        && data.duration is string && data.duration.size() <= 100
        && data.startDate is string && data.startDate.size() <= 100
        && data.groupSize is string && data.groupSize.size() <= 100
        && data.image is string
        && data.highlights is list
        && data.includes is list
        && data.excludes is list
        && data.itinerary is list
        && data.gallery is list
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isAdmin', 'createdAt', 'displayName', 'updatedAt'])
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && (data.isAdmin == false || request.auth.token.email == 'kafehazyad5@gmail.com');
    }

    // --- Collections ---
    
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && (isAdmin() || request.auth.token.email == 'kafehazyad5@gmail.com');
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isValidId(bookingId) && isValidBooking(incoming());
      // Only admins can see and manage all bookings
      allow read, update, delete: if isAdmin();
    }

    match /trips/{tripId} {
      // Trips are public to read
      allow read: if true;
      // Only admins can manage trips
      allow write: if isAdmin();
    }
  }
}
